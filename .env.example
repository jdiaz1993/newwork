# Copy to ".env.local" (never commit .env.local). Required for contact form emails.

# Get an API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where consultation requests are delivered.
# While using Resend's test sender (no CONTACT_FROM_EMAIL): Resend only allows
# sending TO the same email you used to sign up at Resend.
# To use a different inbox (e.g. newworkcustomupholstery@gmail.com): verify a
# domain in Resend, set CONTACT_FROM_EMAIL below, then set CONTACT_TO_EMAIL here.
CONTACT_TO_EMAIL=newworkcustomupholstery@gmail.com

# Optional. After you verify a domain in Resend, use e.g.:
# CONTACT_FROM_EMAIL=New Work <hello@yourdomain.com>
#
# Troubleshooting "send failed":
# - Do NOT set CONTACT_FROM_EMAIL to Gmail/Yahoo/etc. Resend rejects those as `from` until you verify your own domain.
# - Omit CONTACT_FROM_EMAIL to use onboarding@resend.dev; then CONTACT_TO_EMAIL should match your Resend login email for testing.
# - Check Resend dashboard → Logs for the exact error message.
