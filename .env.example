# Copy to ".env.local" (never commit .env.local).

# Admin page login — required to view consultation requests at /admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Random secret used to sign admin session cookies (32+ chars recommended)
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Persistent database for consultation requests (recommended for production).
# Create a free Supabase project, run supabase/consultation_requests.sql in the SQL editor,
# then paste your project URL and service role key here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev only (Windows SSL issues). Never enable in production.
# SUPABASE_INSECURE_TLS=true

# Local fallback only (used when Supabase vars above are not set).
# Optional. Defaults to data/consultations.sqlite in the project root.
# CONSULTATIONS_DB_PATH=/absolute/path/to/consultations.sqlite
